{
	"name": "pili",
	"version": "1.0.0",
	"description": "",
	"main": "app/index.js",
	"scripts": {
		"build": "git pull && npm i && cp .env.example .env && sudo nano .env",
		"prestart": "cd ./app/front && npm run build",
		"start": "node app/back/index.js",

		"postinstall": "concurrently 'npm run install:back' 'npm run install:front'",
        "install:back": "cd ./app/front && npm install",
        "install:front": "cd ./app/back && npm install",
		"format": "prettier . --write",
		"dev:back": "cd ./app/back && npm run dev",
		"dev:front": "cd ./app/front && npm run dev",
		"dev": "concurrently 'npm run dev:back' 'npm run dev:front'"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Zdep88/pili.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/Zdep88/pili/issues"
	},
	"homepage": "https://github.com/Zdep88/pili#readme",
	"devDependencies": {
		"concurrently": "^9.2.1",
		"prettier": "^3.8.1"
	}
}
