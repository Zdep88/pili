# Mode de fonctionnement de NodeJS: development | production
NODE_ENV=development

# Port d'écoute des requêtes sur le serveur backend
SERVER_PORT=3004

# URL complète du serveur backend pour vite
VITE_SERVER_URL=http://localhost:3004

# Phrase secrète de hash pour le cookie d'express-session
EXPRESS_SESSION_SECRET="secret"

# Database configuration
DATABASE_USER=pili
DATABASE_PASSWORD=pili
DATABASE_NAME=pili
